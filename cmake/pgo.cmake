
IF(MSVC)
SET(COMPILE_FLAGS_PGO_INSTRUMENT "/GL")
SET(COMPILE_FLAGS_PGO_OPTIMIZE "/GL")
SET(LINK_FLAGS_PGO_WPO  "/LTCG:NOSTATUS")
SET(LINK_FLAGS_PGO_INSTRUMENT  "/LTCG:PGI")
SET(LINK_FLAGS_PGO_OPTIMIZE  "/LTCG:PGU")
ELSE()
SET(COMPILE_FLAGS_PGO_INSTRUMENT "-fprofile-generate")
SET(COMPILE_FLAGS_PGO_OPTIMIZE "-fprofile-use")
SET(LINK_FLAGS_PGO_WPO)
SET(LINK_FLAGS_PGO_INSTRUMENT  -fprofile-generate)
SET(LINK_FLAGS_PGO_OPTIMIZE  -fprofile-use)
ENDIF()

SET(PGO_TARGETS "mysys;strings;sql;xtradb;mysqld")

FUNCTION(HANDLE_PGO target)
  IF(NOT PGO_MODE)
    return()
  ELSEIF(PGO_MODE STREQUAL "INSTRUMENT" OR PGO_MODE STREQUAL "OPTIMIZE")
    list(FIND PGO_TARGETS ${target} index)
    if(index EQUAL -1)
      return()
    endif()
    message(status "list(FIND PGO_TARGETS ${target} index)")
    target_compile_options(${target} PRIVATE ${COMPILE_FLAGS_PGO_${PGO_MODE}})
    target_link_libraries(${target} ${LINK_FLAGS_PGO_${PGO_MODE}})
  ELSE()
    MESSAGE(FATAL_ERROR "Unknown PGO_MODE ${PGO_MODE}, only INSTRUMENT OR OPTIMIZE are supported")
  ENDIF()
ENDFUNCTION()

